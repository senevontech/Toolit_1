{
  "name": "tools-frontend",
  "private": true,
  "scripts": {
    "dev": "node scripts/clean-next.mjs dev && next dev",
    "build": "node scripts/clean-next.mjs build && next build && node scripts/copy-export-to-dist.mjs",
    "clean": "node scripts/clean-next.mjs all",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "next lint",
    "test": "node scripts/smoke-test.cjs",
    "validate:env": "node scripts/validate-env.mjs",
    "verify": "npm run validate:env && npm run typecheck && npm run lint && npm run build && npm run test"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "browser-image-compression": "^2.0.2",
    "file-save": "^0.2.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.575.0",
    "next": "14.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "qrcode": "^1.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-dropzone": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "25.3.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.5",
    "typescript": "^5.0.0"
  }
}
